JWT_SECRET=change-this-to-a-long-random-string
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
HYBRID_SEARCH_ENABLED=true
PAGE_CONTEXT_EXPAND=true
RETRIEVAL_MULTIPLIER=6
CHUNK_SIZE=800
CHUNK_OVERLAP=180
QUERY_TOP_K_DEFAULT=10
QUERY_TOP_K_LIST=18
ANSWER_MIN_RELEVANCE=0.28
ANSWER_TWO_PASS_ENABLED=true
MATCH_REUSE_INDEXED_DOCS=true
MATCH_LLM_SUMMARY_ONLY=true
MATCH_SCORING_MODE=retrieval
MATCH_USE_LLM_JUDGE=false
MATCH_RETRIEVAL_STAGE1_TOP_K=24
MATCH_JUDGE_BATCH_SIZE=8
MATCH_RESUME_CONTEXT_MAX_CHARS=14000
MATCH_STRENGTH_PARTIAL_MIN_SCORE=45
JD_PARSE_CACHE_ENABLED=true
OLLAMA_TEMPERATURE=0

# ── Meeting summarization ──────────────────────────────────────────────
# Recommended: use a 7B+ model for much better accuracy.
# Run: ollama pull qwen2.5:7b   (or llama3.1:8b, mistral:7b)
# Leave empty to share the global OLLAMA_CHAT_MODEL.
MEETING_CHAT_MODEL=
# Characters per LLM call. Increase for models with larger context windows.
MEETING_CHUNK_CHARS=6000
# Overlap chars between chunks (preserves cross-boundary context).
MEETING_CHUNK_OVERLAP_CHARS=400
# Temperature=0 → deterministic JSON. Higher = more fluent but less structured.
MEETING_TEMPERATURE=0
